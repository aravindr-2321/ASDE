# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set to "anthropic" (default) or "openrouter"
LLM_PROVIDER=anthropic

# Model name
# Anthropic direct : claude-sonnet-4-6  |  claude-opus-4-5  |  claude-haiku-4-5
# OpenRouter       : anthropic/claude-sonnet-4-6  |  openai/gpt-4o
#                    google/gemini-pro-1.5  |  meta-llama/llama-3.1-70b-instruct
#                    mistralai/mistral-large  |  deepseek/deepseek-r1
LLM_MODEL=claude-sonnet-4-6

# ── API Keys ──────────────────────────────────────────────────────────────────
# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenRouter (used when LLM_PROVIDER=openrouter)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Email ─────────────────────────────────────────────────────────────────────
# Gmail:
#   EMAIL_SMTP_HOST=smtp.gmail.com  |  EMAIL_IMAP_HOST=imap.gmail.com
#   EMAIL_PASSWORD = 16-char App Password (myaccount.google.com → Security → App passwords)
#
# Outlook / Hotmail:
#   EMAIL_SMTP_HOST=smtp-mail.outlook.com  |  EMAIL_IMAP_HOST=imap-mail.outlook.com
#   EMAIL_PASSWORD = App Password (account.microsoft.com → Security → Advanced → App passwords)

EMAIL_SENDER=yourname@outlook.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_SMTP_HOST=smtp-mail.outlook.com
EMAIL_SMTP_PORT=587
EMAIL_IMAP_HOST=imap-mail.outlook.com
